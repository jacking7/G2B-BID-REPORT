generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  passwordHash     String
  name             String?
  role             String            @default("user")
  recipients       Recipient[]
  keywordRules     KeywordRule[]
  schedules        ScheduleSetting[]
  collectedResults CollectedResult[]
  mailHistories    MailHistory[]
  passwordResets   PasswordResetToken[]
  socialAccounts   SocialAccount[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Recipient {
  id        String   @id @default(cuid())
  email     String
  name      String?
  active    Boolean  @default(true)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KeywordRule {
  id        String   @id @default(cuid())
  keyword   String
  type      String   @default("include")
  active    Boolean  @default(true)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BidNotice {
  id           String            @id @default(cuid())
  bidNtceNo    String
  bidNtceOrd   String?
  title        String
  organization String?
  noticeDate   DateTime?
  closeDate    DateTime?
  baseAmount   Float?
  detailUrl    String?
  rawJson      String?
  results      CollectedResult[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([bidNtceNo, bidNtceOrd])
}

model CollectedResult {
  id             String    @id @default(cuid())
  bidNoticeId    String
  userId         String
  matchedKeyword String?
  collectedAt    DateTime  @default(now())
  emailedAt      DateTime?
  status         String    @default("collected")
  bidNotice      BidNotice @relation(fields: [bidNoticeId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, collectedAt])
  @@unique([bidNoticeId, userId])
}

model ScheduleSetting {
  id          String   @id @default(cuid())
  collectTime String   @default("18:00")
  sendTime    String   @default("09:00")
  timezone    String   @default("Asia/Seoul")
  active      Boolean  @default(true)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MailHistory {
  id           String   @id @default(cuid())
  userId       String
  recipient    String
  subject      String
  sentAt       DateTime @default(now())
  status       String
  errorMessage String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

model EmailVerificationCode {
  id        String    @id @default(cuid())
  email     String
  codeHash  String
  purpose   String    @default("register")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email, purpose, expiresAt])
}

model OAuthState {
  id          String    @id @default(cuid())
  stateHash   String    @unique
  provider    String
  redirectUri String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([provider, expiresAt])
}

model SocialAccount {
  id             String   @id @default(cuid())
  provider       String
  providerUserId String
  email          String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId, provider])
}
